{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Grant basic IPC event permissions to FezOverlay windows",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:event:default"
  ]
}
