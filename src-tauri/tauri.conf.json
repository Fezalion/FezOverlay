{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "fezoverlay",
  "version": "1.0.7",
  "identifier": "com.fezalion.fezoverlay",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:48000",
    "beforeDevCommand": "npm run build",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "FezOverlay",
        "url": "http://localhost:48000",
        "width": 1280,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": { "../dist": "./dist" },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
